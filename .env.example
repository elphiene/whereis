# ──────────────────────────────────────────────────────────────────────────────
# WhereIs? environment variables
# Copy this file to the appropriate location and fill in values.
# NEVER commit .env files to git.
# ──────────────────────────────────────────────────────────────────────────────


# ── Cloudflare Tunnel (cloudflared.env) ──────────────────────────────────────

# Token from Cloudflare Zero Trust dashboard → Tunnels → your tunnel → Configure
TUNNEL_TOKEN=


# ── Backend (backend/.env) ───────────────────────────────────────────────────

# Port the Bun server listens on (must match docker-compose.yml)
PORT=3000

# Absolute path inside the container where SQLite DB is stored
DATABASE_PATH=/data/whereis.db

# Internal Docker hostname + port for Traccar
TRACCAR_URL=http://traccar:8082

# Traccar admin account credentials (used by backend only — never exposed to frontend)
TRACCAR_ADMIN_EMAIL=admin@whereis.local
TRACCAR_ADMIN_PASSWORD=

# ntfy.sh base URL (use https://ntfy.sh for the public server, or your self-hosted instance)
NTFY_BASE_URL=https://ntfy.sh

# Public-facing URL used when generating invite links: ${PUBLIC_URL}/invite?token=...
PUBLIC_URL=https://tracking.elphiene.com


# ── Frontend (frontend/.env) ─────────────────────────────────────────────────
# Baked into the bundle at build time — change requires a rebuild.

# Used in the Traccar Client deep link during onboarding:
#   traccar://connect?url=${VITE_SERVER_URL}/api&id={uuid}&period=60
# Migrating domains means existing users must redo device setup (onboarding step 4+).
VITE_SERVER_URL=https://tracking.elphiene.com
