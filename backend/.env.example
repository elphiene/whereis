# whereis backend env — copy to .env and fill in real values

# SQLite path inside the container (mapped to ./data on host via volume)
DATABASE_PATH=/data/whereis.db

# Public URL (what the frontend tells users to visit)
PUBLIC_URL=https://eldev.cherrysofa.com

# Traccar admin (the credentials Traccar creates on first run; default is admin/admin
# unless you set it in traccar.xml — change this immediately after first login)
TRACCAR_URL=http://traccar:8082
TRACCAR_ADMIN_EMAIL=admin
TRACCAR_ADMIN_PASSWORD=CHANGE_ME_AFTER_FIRST_LOGIN

# ntfy.sh notification service (for push notifications)
NTFY_BASE_URL=https://ntfy.sh
